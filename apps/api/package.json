{
  "name": "@nest/api",
  "version": "1.0.0",
  "description": "Backend API for Nest financial platform",
  "main": "dist/index.js",
  "private": true,
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit || true && tsc --skipLibCheck",
